{
  "name": "morris-peoplesoft-utilities",
  "version": "1.0.6",
  "private": true,
  "description": "Morris PeopleSoft Utilities — Chrome extension for PeopleSoft Classic and Fluid productivity",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint . && tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit tests/integration tests/smoke",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:a11y": "vitest run tests/a11y",
    "audit:a11y": "vitest run tests/a11y",
    "audit:store": "tsx scripts/audit-store.ts",
    "audit:compliance": "tsx scripts/audit-compliance.ts",
    "audit": "npm run audit:a11y && npm run audit:store && npm run audit:compliance",
    "test:all": "npm run lint && npm run test:coverage && npm run audit && npm run build && npm run audit:store",
    "package": "npm run build && tsx scripts/package-zip.ts",
    "release:check": "npm run lint && npm run test:coverage && npm run audit && npm run package",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "generate:store-assets": "tsx scripts/generate-store-assets.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hackmods/Morris-Peoplesoft-Utilities.git"
  },
  "author": "hackmods (Ryan Morris)",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/archiver": "^8.0.0",
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.1",
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.10",
    "archiver": "^8.0.0",
    "axe-core": "^4.10.3",
    "eslint": "^10.7.0",
    "globals": "^16.2.0",
    "jsdom": "^29.1.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
